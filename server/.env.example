# Copy to .env and fill in values.
# Get TURSO_AUTH_TOKEN from https://turso.tech/app or your Render dashboard.

TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=

JWT_SECRET=change-me-in-production

# Web Push — run: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
